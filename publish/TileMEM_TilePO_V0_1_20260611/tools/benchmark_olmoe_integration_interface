#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
from pathlib import Path
import sys


ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from examples.olmoe_external_cuda_backend import render_markdown_report, run_benchmark  # noqa: E402


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--out-dir", required=True)
    parser.add_argument("--iterations", type=int, default=25)
    parser.add_argument("--m", type=int, default=16)
    parser.add_argument("--n", type=int, default=256)
    parser.add_argument("--k", type=int, default=256)
    args = parser.parse_args()

    try:
        summary = run_benchmark(iterations=args.iterations, m=args.m, n=args.n, k=args.k, build_dir=Path(args.out_dir) / "cuda_build")
    except ValueError as exc:
        print(f"OLMoE integration benchmark rejected arguments: {exc}", file=sys.stderr)
        return 1

    out_dir = Path(args.out_dir)
    out_dir.mkdir(parents=True, exist_ok=True)
    summary_path = out_dir / "olmoe_integration_summary.json"
    markdown_path = out_dir / "olmoe_integration_report.md"
    summary_json = json.dumps(summary, indent=2, sort_keys=True) + "\n"
    summary_path.write_text(summary_json)
    markdown_path.write_text(render_markdown_report(summary))
    print(summary_json, end="")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
