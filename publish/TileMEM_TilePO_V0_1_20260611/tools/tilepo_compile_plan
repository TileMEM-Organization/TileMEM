#!/usr/bin/env python3
import argparse
from pathlib import Path
import sys

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from tilepo.compiler import compile_model_spec, compile_plan


def main() -> int:
    parser = argparse.ArgumentParser()
    inputs = parser.add_mutually_exclusive_group(required=True)
    inputs.add_argument("--plan")
    inputs.add_argument("--model-spec")
    parser.add_argument("--out-dir", required=True)
    args = parser.parse_args()
    if args.model_spec:
        result = compile_model_spec(Path(args.model_spec), Path(args.out_dir))
    else:
        result = compile_plan(Path(args.plan), Path(args.out_dir))
    print(result.mir_path)
    print(result.manifest_path)
    print(result.compiled_plan_path)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
