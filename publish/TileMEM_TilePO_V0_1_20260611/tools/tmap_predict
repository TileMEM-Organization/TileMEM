#!/usr/bin/env python3
from __future__ import annotations

import argparse
from pathlib import Path
import sys


ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT / "TMAP"))

from tmap.predictor import predict_from_summary  # noqa: E402
from tmap.report import write_prediction_outputs  # noqa: E402
from tmap.schema import HardwareProfile  # noqa: E402


def main() -> int:
    parser = argparse.ArgumentParser(description="Run TMAP two-tier prediction over TilePO V0.1 samples.")
    parser.add_argument("--summary", type=Path, required=True, help="TilePO ablation summary JSON")
    parser.add_argument("--hardware-profile", type=Path, required=True, help="TMAP hardware profile JSON")
    parser.add_argument("--out-dir", type=Path, required=True, help="Output directory")
    parser.add_argument("--admit-threshold-pct", type=float, default=3.0)
    parser.add_argument("--target", action="append", default=[], help="Optional target as workload:experts, e.g. mixed:12")
    parser.add_argument(
        "--target-experts",
        default="",
        help="Optional comma-separated expert budgets to scan for every workload",
    )
    parser.add_argument("--allow-extrapolation", action="store_true", help="Allow prediction for unseen expert budgets")
    args = parser.parse_args()

    try:
        if args.target and args.target_experts.strip():
            raise ValueError("cannot combine --target and --target-experts; use one target mode per run")
        hardware = HardwareProfile.from_json_path(args.hardware_profile)
        target_experts = _parse_int_list(args.target_experts)
        result = predict_from_summary(
            args.summary,
            hardware,
            admit_threshold_pct=args.admit_threshold_pct,
            target_experts=target_experts,
            target_pairs=_parse_targets(args.target),
            allow_extrapolation=args.allow_extrapolation,
        )
        summary_path, report_path = write_prediction_outputs(result, args.out_dir)
    except Exception as exc:  # noqa: BLE001 - CLI should report concise failures.
        print(f"TMAP prediction failed: {exc}", file=sys.stderr)
        return 2

    print(summary_path)
    print(report_path)
    print(
        "TMAP summary: "
        f"admit={result.summary['admit_tilepo']} "
        f"fallback={result.summary['fallback_kt']} "
        f"rank_accuracy={result.summary['rank_accuracy']:.2f}"
    )
    return 0


def _parse_int_list(value: str) -> list[int]:
    if not value.strip():
        return []
    return [int(item.strip()) for item in value.split(",") if item.strip()]


def _parse_targets(values: list[str]) -> list[tuple[str, int]]:
    targets = []
    for value in values:
        if ":" not in value:
            raise ValueError(f"target must be workload:experts, got {value!r}")
        workload, experts = value.split(":", 1)
        workload = workload.strip()
        if not workload:
            raise ValueError(f"target workload is empty: {value!r}")
        targets.append((workload, int(experts.strip())))
    return targets


if __name__ == "__main__":
    raise SystemExit(main())
