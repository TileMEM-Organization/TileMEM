#!/usr/bin/env python3
from __future__ import annotations

import argparse
from pathlib import Path
import sys

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from tilepo.reporting.adaptive_granularity import (  # noqa: E402
    AdaptiveGranularityReportError,
    generate_adaptive_granularity_report,
)


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--manifest", required=True)
    parser.add_argument("--out-dir", default="")
    parser.add_argument("--require-real", action="store_true")
    args = parser.parse_args()
    manifest = Path(args.manifest)
    out_dir = Path(args.out_dir) if args.out_dir else manifest.parent
    try:
        result = generate_adaptive_granularity_report(manifest, out_dir, require_real=args.require_real)
    except (AdaptiveGranularityReportError, ValueError) as exc:
        print(f"TilePO adaptive granularity reporter rejected evidence: {exc}", file=sys.stderr)
        return 1
    print(result.summary_path)
    print(result.markdown_path)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
